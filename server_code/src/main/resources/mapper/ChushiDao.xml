<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.ChushiDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.ChushiEntity" id="chushiMap">
        <result property="gonghao" column="gonghao"/>
        <result property="mima" column="mima"/>
        <result property="chushixingming" column="chushixingming"/>
        <result property="xingbie" column="xingbie"/>
        <result property="touxiang" column="touxiang"/>
        <result property="nianling" column="nianling"/>
    </resultMap>

    <select id="selectListView"
		resultType="com.cl.entity.view.ChushiView" >

		SELECT  chushi.* FROM chushi  chushi 	        
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.cl.entity.view.ChushiView" >
		SELECT * FROM chushi  chushi <where>${ew.sqlSegment}</where>
	</select>



</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.GonggaoDao">

    <select id="selectListView" resultType="com.cl.entity.view.GonggaoView" >
        SELECT  gonggao.* FROM gonggao  gonggao
        <where> 1=1
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
    </select>

    <select id="selectView" resultType="com.cl.entity.view.GonggaoView" >
        SELECT  gonggao.* FROM gonggao  gonggao
        <where> 1=1
            <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
                AND ${ew.sqlSegment}
            </if>
        </where>
    </select>

</mapper>
r\n\t\t\t\tpadding: 0px;\r\n\t\t\t\tbackground: none;\r\n\t\t\t\t// 二级菜单\r\n\t\t\t\t.second-item {\r\n\t\t\t\t\tpadding: 0 40px;\r\n\t\t\t\t\tcolor: #666;\r\n\t\t\t\t\tbackground: none;\r\n\t\t\t\t\tline-height: 50px;\r\n\t\t\t\t\theight: 50px;\r\n\t\t\t\t}\r\n\t\t\t\t// 二级悬浮\r\n\t\t\t\t.second-item:hover {\r\n\t\t\t\t\tpadding: 0 40px;\r\n\t\t\t\t\tcolor: #f00;\r\n\t\t\t\t\tbackground: greenyellow;\r\n\t\t\t\t\tline-height: 50px;\r\n\t\t\t\t\theight: 50px;\r\n\t\t\t\t}\r\n\t\t\t\t// 二级选中\r\n\t\t\t\t.is-active.second-item {\r\n\t\t\t\t\tpadding: 0 40px;\r\n\t\t\t\t\tcolor: #000;\r\n\t\t\t\t\tbackground: none;\r\n\t\t\t\t\tline-height: 50px;\r\n\t\t\t\t\theight: 50px;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n</style>\r\n<style>\r\n/* 菜单展开样式 */\n/* 中间内容总盒子 */\n.main-container{\n    margin: 0px 0px 0px 210px;\n    padding: 80px 0px 0px !important;\n    background: #eaeaea;\n    overflow: hidden;\n}\n\n/* 总盒子 */\n.menu_wrapper{\n    width: 210px;\n    background: #7d97f4;\n    height: 100%;\n    overflow: hidden;\n    position: fixed;\n    top: 80px;\n    left: 0px;\n    border-width: 0px;\n    border-style: solid;\n    border-color: rgb(255, 255, 255);\n    padding: 20px 0 60px;\n    transition: all 0.3s ease-in-out 0s;\n    font-size:15px;\n    box-shadow: 2px 0 6px 0 rgba(69, 90, 100, 0.1);\n}\n/* 菜单盒子 */\n.menu_view{\n    height: 100%;\n    background: none;\n    color: rgb(255, 255, 255);\n    padding: 0px 0px 100px;\n    border: 0px;\n    transition: all 0s ease 0s;\n}\n\n/* 一级菜单 */\n/* 盒子 */\n.menu_view li.el-sub-menu{\n    padding: 0px!important;\n    cursor: pointer;\n    position: relative;\n    white-space: nowrap;\n    background: none;\n    color: rgb(51, 51, 51);\n    margin: 0px 0px 10px;\n}\n/* 图标 */\n.menu_view li.el-sub-menu .el-sub-menu__title .el-icon-location{\n    vertical-align: middle;\n    margin: 0px 5px 0px 0px;\n    width: 20px;\n    text-align: center;\n    font-size: 20px;\n    color: inherit;\n}\n/* item */\n.menu_view li.el-sub-menu .el-sub-menu__title{\n    height: 45px;\n    padding: 0px 10px 0px 20px;\n    color: rgb(0, 0, 0);\n    background: none;\n    line-height: 45px;\n    border-width: 0px 0px 0px;\n    border-style: solid;\n    border-color: rgba(255, 255, 255,.3);\n    font-weight: 600;\n    margin: 0px;\n    transition: all 0s ease 0s;\n}\n/* 悬浮*/\n.menu_view li.el-sub-menu .el-sub-menu__title:hover{\n    background: url(http://clfile.zggen.cn/20240915/ce4c1e151f9248e583350c2bc4f46a50.png) no-repeat center top / 100% 100%;\n    color: rgba(255, 255, 255,1);\n    border-radius: 0px;\n}\n/* 选中 */\n.menu_view li.el-sub-menu .el-sub-menu__title.is-active{\n    background: url(http://clfile.zggen.cn/20240915/ce4c1e151f9248e583350c2bc4f46a50.png) no-repeat center top / 100% 100%;\n    color: rgba(255, 255, 255,1);\n    border-radius: 0px;\n}\n/* 箭头*/\n.menu_view li.el-sub-menu .el-sub-menu__title .el-sub-menu__icon-arrow{\n    position: absolute;\n    margin: -6px 10px 0px 8px;\n    font-size: 12px;\n    vertical-align: middle;\n    color: inherit;\n    right: 10px;\n}\n.menu_view li.el-menu-item{\n    height: 45px;\n    padding: 0px 10px 0px 20px;\n    color: rgb(0, 0, 0);\n    background: none;\n    line-height: 45px;\n    border-width: 0 0 0px;\n    border-style: solid;\n    border-color: rgba(255, 255, 255,.3);\n    font-weight: 600;\n    margin: 0px 0px 10px;\n    transition: all 0s ease 0s;\n}\n.menu_view li.el-menu-item:hover{\n    background: url(http://clfile.zggen.cn/20240915/ce4c1e151f9248e583350c2bc4f46a50.png) no-repeat center top / 100% 100%;\n    color: rgba(255, 255, 255,1);\n    border-radius: 0px;\n}\n.menu_view li.el-menu-item.is-active{\n    background: url(http://clfile.zggen.cn/20240915/ce4c1e151f9248e583350c2bc4f46a50.png) no-repeat center top / 100% 100%;\n    color: rgba(255, 255, 255,1);\n    border-radius: 0px;\n}\n\n/* 二级菜单 */\n/* 盒子 */\n.menu_view li .el-menu--inline{\n    width: 88% !important;\n    border: none;\n    margin: 10px auto;\n    padding: 0px!important;\n    box-sizing: border-box;\n    background: #fff;\n    border-radius: 4px;\n    overflow: hidden;\n}\n/* item */\n.menu_view li .el-menu--inline .second-item{\n    display: block;\n    margin: 0px!important;\n    padding:0px!important;\n    height: 40px;\n    line-height: 40px;\n    padding: 0px 0px 0px 0px;\n    background: none;\n    border-width: 0px;\n    border-style: solid;\n    border-color: rgb(251, 190, 98);\n    box-shadow: none;\n    color: rgb(99, 99, 99);\n    font-size:15px;\n    font-weight:500;\n    text-align:center;\n}\n/* 悬浮 */\n.menu_view li .el-menu--inline .second-item:hover{\n    background: url(http://clfile.zggen.cn/20240915/1640c7eb9b714e839138ca9ebc0bb12e.png) no-repeat 90% center / 9px,#ffc4bf;\n    color: #fe7062;\n}\n/* 选中 */\n.menu_view li .el-menu--inline .second-item.is-active{\n    background: url(http://clfile.zggen.cn/20240915/1640c7eb9b714e839138ca9ebc0bb12e.png) no-repeat 90% center / 9px,#ffc4bf;\n    color: #fe7062;\n}\n\r\n</style>"]},"metadata":{},"sourceType":"script","externalDependencies":[]}